    .project-list {
  border-top: 1px solid rgba(148, 163, 184, 0.28);
}

.project-row {
  display: grid;
  grid-template-columns:
    minmax(10rem, 0.62fr)
    minmax(15rem, 1fr)
    minmax(20rem, 1.45fr);
  gap: clamp(1.5rem, 3vw, 2.8rem);
  align-items: center;
