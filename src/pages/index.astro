---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEducation = await getCollection('education');
const allProjects = await getCollection('projects');
const allNews = await getCollection('news');
const allExperiences = await getCollection('experience');


// Latest ONE news
const latestNews = allNews
  .slice()
  .sort((a, b) => {
    const ta = Date.parse(a.data.date ?? '') || 0;
    const tb = Date.parse(b.data.date ?? '') || 0;
    return tb - ta;
  })
  .slice(0, 1);

// education
const education = allEducation
  .slice()
  .sort((a, b) => {
    const yearA = parseInt(a.data.start?.match(/\d{4}/)?.[0] ?? '0');
    const yearB = parseInt(b.data.start?.match(/\d{4}/)?.[0] ?? '0');
    return yearB - yearA; // latest first
  });


// Latest 3 experiences
const experiences = allExperiences
  .slice()
  .sort((a, b) => (b.data.start ?? '').localeCompare(a.data.start ?? ''))
  .slice(0, 1);


// Skills
const skills = [
  {
    title: "MECHANICAL PRODUCT DESIGN",
    cmd: "$ cat skills/product-design.txt",
    tags: [
      "SolidWorks & CATIA V5 (complex parts, large assemblies, drawings)",
      "GD&T & tolerance stack-up analysis",
      "Design for Manufacturing (DFM) & Design for Assembly (DFA)",
      "BOM creation + vendor sourcing + procurement coordination",
      "Machining-aware design (milling, turning, fabrication constraints)",
      "Test fixtures & experimental rig design",
      "Design iteration from prototype to validated hardware"
    ],
  },
  {
    title: "STRUCTURAL ANALYSIS (FEA)",
    cmd: "$ cat skills/structural-fea.txt",
    tags: [
      "ANSYS Mechanical (static structural, modal)",
      "Boundary conditions & load case definition",
      "Mesh convergence / mesh independence studies",
      "Stress, deformation & safety factor evaluation",
      "Contact modeling & joint behavior",
      "Failure risk assessment & design refinement"
    ],
  },
  {
    title: "THERMAL & FLUID ANALYSIS (CFD)",
    cmd: "$ cat skills/thermal-fluid.txt",
    tags: [
      "ANSYS Fluent (RANS / URANS)",
      "Internal & external flow simulations",
      "Convective heat transfer modeling",
      "Turbulence modeling & solution controls",
      "Post-processing of lift/drag & flow fields",
      "Low-Re experimental validation & scaling analysis"
    ],
  },
  {
    title: "PROTOTYPING, TEST & DATA",
    cmd: "$ cat skills/testing-data.txt",
    tags: [
      "Experimental setup build & instrumentation integration",
      "Sensor calibration & uncertainty quantification",
      "MATLAB automation for data reduction",
      "Python for scientific computing & post-processing",
      "LabVIEW-based data acquisition",
      "Hardware troubleshooting & iteration under test"
    ],
  },
];



// Max 6 projects (featured first if exists)
const toSortableTime = (p) => {
  const raw = (p.data.date ?? p.data.period ?? '').toString().trim();
  if (!raw) return 0;

  // 1) ISO-like: YYYY-MM or YYYY-MM-DD
  const iso = raw.match(/^(\d{4})(?:-(\d{2}))?(?:-(\d{2}))?/);
  if (iso) {
    const y = Number(iso[1]);
    const m = Number(iso[2] ?? '01');
    const d = Number(iso[3] ?? '01');
    return new Date(y, m - 1, d).getTime();
  }

  // 2) Month name + year: "Aug 2024", "August 2024"
  const my = raw.match(/(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)[a-z]*\s+(\d{4})/i);
  if (my) {
    const months = { jan:1,feb:2,mar:3,apr:4,may:5,jun:6,jul:7,aug:8,sep:9,oct:10,nov:11,dec:12 };
    const mon = months[my[1].slice(0,3).toLowerCase()] ?? 1;
    const y = Number(my[2]);
    return new Date(y, mon - 1, 1).getTime();
  }

  // 3) Year anywhere: "2020", "2020–2021", "Fall 2023"
  const yOnly = raw.match(/(\d{4})/);
  if (yOnly) {
    const y = Number(yOnly[1]);
    return new Date(y, 0, 1).getTime();
  }

  return 0;
};

// Sort latest first (by best-available date/period)
const sortedProjects = allProjects
  .slice()
  .sort((a, b) => toSortableTime(b) - toSortableTime(a));

// Featured first (but still sorted latest-first inside featured)
const featured = sortedProjects.filter((p) => p.data.featured);
const projects = (featured.length ? featured : sortedProjects).slice(0, 4);
---

<BaseLayout
  title="Sandip Gautam – Portfolio"
  description="Personal website built with Astro + Tailwind."
>
  <!-- Hero -->
  <section class="space-y-6">
    <div class="space-y-3">
     <h1 class="typewriter text-3xl sm:text-4xl font-bold tracking-tight dark:text-emerald-300">
  Hi, I am Sandip<span class="cursor-blink ml-1">|</span>
</h1>
      <p class="t-muted text-lg leading-relaxed">
        <span class="font-medium text-slate-900 dark:text-[#d7fbe7]">
          Mechanical Engineering M.S. student
        </span>{' '}
        specializing in thermal-fluid systems, CFD, and experimental analysis. I translate physical insight into practical
        design decisions, produce clear technical documentation, and collaborate across teams. Seeking early-career roles
        in product design, HVAC systems, and thermal-fluid analysis.
      </p>

      <div class="t-mono t-meta text-xs">
        $ interests: thermal-fluid • HVAC • CFD • experiments
      </div>
    </div>

    <!-- Buttons -->
    <div class="flex flex-wrap gap-2">
      <a
        href="/cv/Sandip_Gautam_Grad_Resume.pdf"
        target="_blank"
        rel="noopener"
        class="t-mono rounded-lg bg-slate-900 px-4 py-2 text-xs font-semibold text-white hover:bg-slate-800
              dark:bg-emerald-400/90 dark:text-black dark:hover:bg-emerald-300"
      >
        VIEW RESUME
      </a>


     
    </div>

    <!-- Latest News Ticker (terminal marquee) -->
{latestNews.length ? (
  <section class="mt-12">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-xs font-semibold tracking-wider text-slate-700 uppercase dark:text-emerald-400">
        LATEST NEWS
      </h2>

      <a href="/news" class="t-mono t-meta text-xs hover:text-slate-900 dark:hover:text-emerald-300">
        ALL →
      </a>
    </div>

    <div>
      <a
        href={`/news/${latestNews[0].slug}`}
        class="t-card block p-6"
      >
        <div class="font-semibold text-slate-900 dark:text-[#d7fbe7]">
          {latestNews[0].data.title}
        </div>

        {latestNews[0].data.date ? (
          <div class="mt-2 t-meta text-xs">
            {new Date(latestNews[0].data.date).toLocaleDateString(undefined, {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </div>
        ) : null}
      </a>
    </div>
  </section>
) : null}
  </section>

  <!-- Education (homepage only) -->
  {education.length ? (
    <section class="mt-12">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-xs font-semibold tracking-wider text-slate-700 uppercase
           dark:text-emerald-400">
  EDUCATION
</h2>

      </div>

      <div class="space-y-4">
        {education.map((ed) => (
          <div class="t-card p-6">
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
              <div class="t-mono t-meta text-xs">
                {ed.data.start}{ed.data.end ? ` - ${ed.data.end}` : ''}
              </div>
              <span class="text-slate-300 dark:text-white/20">•</span>
              <div class="t-meta text-xs">
                <span class="t-mono font-semibold text-slate-800 dark:text-[#d7fbe7]">
                  {ed.data.school}
                </span>
                {ed.data.location ? ` — ${ed.data.location}` : ''}
              </div>
            </div>

            <div class="mt-2 text-lg font-semibold text-slate-900 dark:text-[#d7fbe7]">
              {ed.data.degree}
            </div>

            {ed.data.courses?.length ? (
              <div class="mt-4">
                <div class="t-mono t-meta text-xs mb-2">COURSEWORK</div>
                <div class="flex flex-wrap gap-2">
                  {ed.data.courses.map((c) => (
                    <span class="t-badge t-mono">{c}</span>
                  ))}
                </div>
              </div>
            ) : null}
          </div>
        ))}
      </div>
    </section>
  ) : null}

 
{/* Skills */}
<section class="mt-12 skills-wrap">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-xs font-semibold tracking-wider text-slate-700 uppercase dark:text-emerald-400">
      SKILLS
    </h2>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    {skills.map((s) => (
      <div class="t-card p-6 skills-card">
        <div class="t-mono text-xs font-semibold tracking-wider text-slate-800 dark:text-[#d7fbe7]">
          {s.title}
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
          {s.tags.map((t) => (
            <span class="t-badge t-mono skills-chip">{t}</span>
          ))}
        </div>
      </div>
    ))}
  </div>

  <style>
    .skills-wrap .skills-card {
      position: relative;
      overflow: hidden;
      transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
    }

    .skills-wrap .skills-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.10);
    }

    :global(.dark) .skills-wrap .skills-card:hover {
      box-shadow: 0 16px 44px rgba(0, 0, 0, 0.40);
    }

    .skills-wrap .skills-chip {
      position: relative;
      border-radius: 999px;
      padding: 8px 10px;
      font-size: 12px;
      line-height: 1.1;
      transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease, background 150ms ease;
    }

    .skills-wrap .skills-chip:hover {
      transform: translateY(-1px);
      border-color: rgba(16, 185, 129, 0.55);
      background: rgba(16, 185, 129, 0.10);
      box-shadow:
        0 0 0 1px rgba(16, 185, 129, 0.55),
        0 0 18px rgba(16, 185, 129, 0.28);
    }

    @media (prefers-reduced-motion: reduce) {
      .skills-wrap .skills-card,
      .skills-wrap .skills-chip {
        transition: none !important;
      }

      .skills-wrap .skills-card:hover,
      .skills-wrap .skills-chip:hover {
        transform: none !important;
      }
    }
  </style>
</section>


  <!-- Experience (text-only) -->
  <section class="mt-12">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-xs font-semibold tracking-wider text-slate-700 uppercase
           dark:text-emerald-400">
  Experience
</h2>


      <a href="/experience" class="t-mono t-meta text-xs hover:text-slate-900 dark:hover:text-emerald-300">
        ALL →
      </a>
    </div>

    <div class="space-y-4">
      {experiences.map((e) => (
        <a
          href={`/experience/${e.slug}`}
          class="t-card block p-6 transition hover:-translate-y-0.5"
        >
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
            <span class="t-mono t-meta text-xs">
              {(e.data.start ?? '')}{e.data.end ? ` - ${e.data.end}` : ' - Present'}
            </span>

            <span class="text-slate-300 dark:text-white/20">•</span>

            <span class="t-meta text-xs">
              <span class="t-mono font-semibold text-slate-800 dark:text-[#d7fbe7]">
                {e.data.company}
              </span>
              {e.data.location ? ` — ${e.data.location}` : ''}
            </span>
          </div>

          <h3 class="mt-2 text-lg font-semibold text-slate-900 dark:text-[#d7fbe7]">
            {e.data.title}
          </h3>

          <p class="t-muted mt-2 text-sm">
            {e.data.summary ?? 'View details.'}
          </p>
        </a>
      ))}
    </div>
  </section>







  <!-- Projects (max 6) -->
  <section class="mt-12">
    
    <div class="mb-4 flex items-center justify-between">
    <h2 class="text-xs font-semibold tracking-wider text-slate-700 uppercase dark:text-emerald-400">
      ENGINEERING PROJECTS
    </h2>
  </div>


    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-2">
      
  {projects.map((p) => {
    const cover = p.data.coverImage ?? p.data.cover ?? null;

    return (
      <a
        href={`/projects/${p.slug}`}
        class="t-card group block p-5 transition hover:-translate-y-0.5"
      >
        {/* Image Section */}
        <section class="mb-4">
          <div class="relative h-44 w-full overflow-hidden rounded-xl bg-slate-100 dark:bg-white/5">
            {cover ? (
              <img
                src={cover}
                alt={p.data.coverAlt ?? p.data.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.05]"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center t-mono t-meta text-xs">
                No preview
              </div>
            )}
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/10 via-transparent to-transparent"></div>
          </div>
        </section>

        {/* Text Section */}
        <section class="space-y-2">
          <div class="t-mono t-meta text-xs">
            {p.data.date ?? p.data.period ?? 'Project'}
          </div>

          <div class="font-semibold text-slate-900 dark:text-[#d7fbe7]">
            {p.data.title}
          </div>

          {Array.isArray(p.data.description2) && p.data.description2.length > 0 && (
  <ul class="mt-3 space-y-3 text-sm text-slate-600 dark:text-slate-300 list-disc pl-5">
  {p.data.description2.slice(0, 3).map((item, idx) => (
    <li key={idx} class="leading-6">
      {item}
    </li>
  ))}
</ul>
)}
        </section>
      </a>
    );
  })}
</div>
  </section>

  <!-- News ticker animation (kept local) -->
  <style>
    .news-ticker { animation: ticker 14s linear infinite; }
    .news-ticker:hover { animation-play-state: paused; }

    @media (prefers-reduced-motion: reduce) {
      .news-ticker { animation: none !important; transform: none !important; }
    }

    @keyframes ticker {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>
</BaseLayout>
