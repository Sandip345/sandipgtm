---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEducation = await getCollection('education');
const allProjects = await getCollection('projects');
const allNews = await getCollection('news');
const allExperiences = await getCollection('experience');

const monthMap = {
  jan: 1,
  feb: 2,
  mar: 3,
  apr: 4,
  may: 5,
  jun: 6,
  jul: 7,
  aug: 8,
  sep: 9,
  oct: 10,
  nov: 11,
  dec: 12,
};

const toSortableTime = (value) => {
  const raw = (value ?? '').toString().trim();
  if (!raw) return 0;

  const iso = raw.match(/^(\d{4})(?:-(\d{2}))?(?:-(\d{2}))?/);
  if (iso) {
    return new Date(
      Number(iso[1]),
      Number(iso[2] ?? '01') - 1,
      Number(iso[3] ?? '01')
    ).getTime();
  }

  const monthYear = raw.match(
    /(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)[a-z]*\s+(\d{4})/i
  );
  if (monthYear) {
    return new Date(
      Number(monthYear[2]),
      (monthMap[monthYear[1].slice(0, 3).toLowerCase()] ?? 1) - 1,
      1
    ).getTime();
  }

  const yearOnly = raw.match(/(\d{4})/);
  if (yearOnly) {
    return new Date(Number(yearOnly[1]), 0, 1).getTime();
  }

  return 0;
};

const formatSafeDate = (value) => {
  if (!value) return '';

  const raw = value instanceof Date ? value : value.toString().trim();
  const date =
    raw instanceof Date
      ? raw
      : new Date(/^\d{4}-\d{2}-\d{2}$/.test(raw) ? `${raw}T00:00:00` : raw);

  if (Number.isNaN(date.getTime())) {
    return value.toString();
  }

  return date.toLocaleDateString(undefined, {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};

// Latest ONE news
const latestNews = allNews
  .slice()
  .sort(
    (a, b) =>
      toSortableTime(b.data.date) -
      toSortableTime(a.data.date)
  )
  .slice(0, 1);

// Education
const education = allEducation
  .slice()
  .sort((a, b) => {
    const endDiff = toSortableTime(b.data.end) - toSortableTime(a.data.end);
    if (endDiff !== 0) return endDiff;
    return toSortableTime(b.data.start) - toSortableTime(a.data.start);
  });

// Latest experience
const experiences = allExperiences
  .slice()
  .sort((a, b) => {
    const startDiff = toSortableTime(b.data.start) - toSortableTime(a.data.start);
    if (startDiff !== 0) return startDiff;
    return toSortableTime(b.data.end) - toSortableTime(a.data.end);
  })
  .slice(0, 1);

// Skills
const skills = [
  {
    title: "MECHANICAL PRODUCT DESIGN",
    icon: "⚙️",
    tags: [
      "SolidWorks & CATIA V5",
      "GD&T",
      "Design for Manufacturing",
      "BOM & Procurement",
      "Test Fixtures & Rig Design",
      "Prototype & Validation"
    ],
  },
  {
    title: "STRUCTURAL ANALYSIS (FEA)",
    icon: "🔩",
    tags: [
      "ANSYS Mechanical",
      "Static & Dynamic Analysis",
      "Stress & Failure Assessment"
    ],
  },
  {
    title: "THERMAL & FLUID ANALYSIS",
    icon: "🌊",
    tags: [
      "ANSYS Fluent (CFD)",
      "Internal & External Flows",
      "Heat Transfer Modeling",
      "Turbulence Modeling",
      "Experimental Design & Analysis",
    ],
  },
  {
    title: "PROTOTYPING, TEST & DATA",
    icon: "📊",
    tags: [
      "Experimental Setup & Instrumentation",
      "Sensor Calibration & Uncertainty",
      "MATLAB & Python",
      "LabVIEW Data Acquisition",
      "Hardware Troubleshooting"
    ],
  },
];

// Projects - sort and pick featured/latest
const sortedProjects = allProjects
  .slice()
  .sort((a, b) => {
    const timeDiff =
      toSortableTime(b.data.date ?? b.data.period) -
      toSortableTime(a.data.date ?? a.data.period);

    if (timeDiff !== 0) return timeDiff;
    return (a.data.title ?? '').localeCompare(b.data.title ?? '');
  });

const featured = sortedProjects.filter((p) => p.data.featured);
const projects = (featured.length ? featured : sortedProjects).slice(0, 4);


const experienceHighlights = (entry) => {
  const body = entry.body ?? '';
  return body
    .split('\n')
    .map((line) => line.trim())
    .filter((line) => /^[-*]\s+/.test(line))
    .map((line) => line.replace(/^[-*]\s+/, ''))
    .slice(0, 4);
};
