  line-height: 1.4;
  transition:
    color 160ms ease,
    transform 160ms ease;
}

.project-row:hover .project-main h3 {
  color: #059669;
  transform: translateY(-2px);
}

.project-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.9rem;
  margin-top: 0.8rem;
  font-size: 0.68rem;
}

.project-tags {
