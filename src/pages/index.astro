    color 160ms ease,
    transform 160ms ease;
}

.latest-news-all:hover {
  color: #059669;
  transform: translateX(2px);
}

.latest-news-feature {
  position: relative;
  display: grid;
  grid-template-columns: minmax(14rem, 0.72fr) minmax(0, 1.28fr);
  gap: clamp(1.6rem, 4vw, 3.5rem);
  align-items: center;
  padding: 1rem 0 2.25rem;
  color: inherit;
  text-decoration: none;
}

.latest-news-image {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  border-radius: 0.8rem;
  background: rgba(148, 163, 184, 0.09);
}

.latest-news-image::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 3;
  border: 1px solid rgba(15, 23, 42, 0.07);
  border-radius: inherit;
  pointer-events: none;
}

.latest-news-image img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 350ms ease;
}

.latest-news-feature:hover .latest-news-image img {
  transform: scale(1.035);
}

/* No-image gradient placeholder */

.latest-news-placeholder {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 100%;
  overflow: hidden;
  border-radius: inherit;
  background:
    radial-gradient(
      circle at 18% 20%,
      rgba(16, 185, 129, 0.34),
      transparent 42%
    ),
    radial-gradient(
      circle at 82% 78%,
      rgba(52, 211, 153, 0.18),
      transparent 42%
    ),
    linear-gradient(
      135deg,
      #07110e 0%,
      #0b1720 48%,
      #0c2b21 100%
    );
}

.latest-news-placeholder::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(
      120deg,
      transparent 20%,
      rgba(16, 185, 129, 0.07) 50%,
      transparent 80%
    );
  transform: translateX(-70%);
  transition: transform 500ms ease;
}

.latest-news-feature:hover .latest-news-placeholder::before {
  transform: translateX(70%);
}

.placeholder-grid {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(
      rgba(16, 185, 129, 0.065) 1px,
      transparent 1px
    ),
    linear-gradient(
      90deg,
      rgba(16, 185, 129, 0.065) 1px,
      transparent 1px
    );
  background-size: 36px 36px;
  -webkit-mask-image: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.95),
    transparent
  );
  mask-image: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.95),
    transparent
  );
}

.placeholder-content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-label {
  color: rgba(236, 253, 245, 0.92);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.latest-news-badge {
  position: absolute;
  top: 0.8rem;
  left: 0.8rem;
  z-index: 4;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 1.7rem;
  padding: 0 0.6rem;
  border: 1px solid rgba(255, 255, 255, 0.45);
  border-radius: 0.35rem;
  background: rgba(15, 23, 42, 0.66);
  color: #ffffff;
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  backdrop-filter: blur(8px);
}

.latest-news-copy {
  min-width: 0;
}

.latest-news-date {
  display: block;
  margin-bottom: 0.75rem;
  color: #059669;
  font-size: 0.62rem;   /* was 0.67rem */
  font-weight: 600;
  letter-spacing: 0.04em;
}

.latest-news-copy h3 {
  max-width: 26ch;
  margin: 0;
  color: #0f172a;
  font-size: clamp(1.2rem, 2.3vw, 1.8rem);
  line-height: 1.35;
  font-weight: 750;
  letter-spacing: -0.03em;
  transition: color 160ms ease;
}

.latest-news-feature:hover .latest-news-copy h3 {
  color: #059669;
}

.latest-news-open {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  margin-top: 1.3rem;
  color: #64748b;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.08em;
}

.latest-news-open > span {
  color: #10b981;
  transition: transform 160ms ease;
}

.latest-news-feature:hover .latest-news-open > span {
  transform: translate(2px, -2px);
}

/* Dark mode */

:global(.dark) .latest-news-heading {
  border-color: rgba(255, 255, 255, 0.1);
}

:global(.dark) .latest-news-heading h2,
:global(.dark) .latest-news-copy h3 {
  color: #d7fbe7;
}

:global(.dark) .latest-news-all,
:global(.dark) .latest-news-open {
  color: #94a3b8;
}

:global(.dark) .latest-news-image {
  background: rgba(255, 255, 255, 0.04);
}

:global(.dark) .latest-news-image::after {
  border-color: rgba(255, 255, 255, 0.08);
}

/* Responsive */

@media (max-width: 760px) {
  .latest-news-feature {
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .latest-news-copy h3 {
    max-width: none;
  }
}

@media (max-width: 520px) {
  .latest-news-heading {
    align-items: center;
    gap: 1rem;
  }

  .latest-news-heading h2 {
    font-size: 1.05rem;
  }

  .latest-news-all {
    flex-shrink: 0;
    font-size: 0.58rem;
  }

  .latest-news-image {
    aspect-ratio: 16 / 10;
  }

  .latest-news-copy h3 {
    font-size: 1.3rem;
  }
}
    /* ══════════════════════════════════════════
       EDUCATION + SKILLS
       ══════════════════════════════════════════ */

    .education-skills-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
      gap: clamp(3.5rem, 6vw, 6.5rem);
      align-items: start;
    }

    .subsection-heading {
      margin-bottom: 1.15rem;
    }

    .subsection-heading h2 {
      margin: 0;
      color: #1e293b;
      font-size: 0.78rem;
      font-weight: 800;
      letter-spacing: 0.08em;
    }

    .subsection-heading > span {
      display: block;
      width: 2.65rem;
      height: 1px;
      margin-top: 0.85rem;
      background: #10b981;
    }

    /* Education */

    .education-timeline {
      position: relative;
    }

    .education-row {
      display: grid;
      grid-template-columns: 7rem 1.1rem minmax(0, 1fr);
      gap: 0.85rem;
      min-height: 12.4rem;
    }

    .education-row:last-child {
      min-height: auto;
    }

    .education-date {
      display: flex;
      flex-wrap: wrap;
      align-content: flex-start;
      gap: 0.1rem 0.4rem;
      padding-top: 0.25rem;
      color: #059669;
      font-size: 0.66rem;
      font-weight: 500;
      line-height: 1.65;
    }

    .education-date-separator {
      color: #10b981;
    }

    .education-marker {
      position: relative;
      display: flex;
      justify-content: center;
    }

    .education-marker::after {
      content: "";
      position: absolute;
      top: 0.72rem;
      bottom: 0;
      left: 50%;
      width: 1px;
      background: linear-gradient(
        to bottom,
        rgba(16, 185, 129, 0.72),
        rgba(148, 163, 184, 0.3)
      );
      transform: translateX(-50%);
    }

    .education-row:last-child .education-marker::after {
      bottom: -0.65rem;
    }

    .education-marker span {
      position: relative;
      z-index: 1;
      width: 0.78rem;
      height: 0.78rem;
      margin-top: 0.25rem;
      border: 2px solid #6ee7b7;
      border-radius: 50%;
      background: #10b981;
      box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.11);
    }

    .education-content {
      padding-bottom: 2.8rem;
    }

    .education-row:last-child .education-content {
      padding-bottom: 0;
    }

    .education-content h3 {
      margin: 0;
      color: #1e293b;
      font-size: clamp(0.98rem, 1.35vw, 1.1rem);
      font-weight: 750;
      line-height: 1.4;
      letter-spacing: -0.015em;
    }

    .education-school {
      display: flex;
      flex-wrap: wrap;
      gap: 0.2rem;
      margin: 0.34rem 0 0;
      color: #64748b;
      font-size: 0.75rem;
      line-height: 1.55;
    }

    .education-school strong {
      color: #334155;
      font-weight: 700;
    }

    .school-divider {
      color: #94a3b8;
    }

    .education-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.42rem 0.5rem;
      margin-top: 0.78rem;
    }

    .education-tag {
      display: inline-flex;
      align-items: center;
      min-height: 1.5rem;
      padding: 0.14rem 0.6rem;
      border: 1px solid rgba(16, 185, 129, 0.22);
      border-radius: 999px;
      background: transparent;
      color: #059669;
      font-size: 0.59rem;
      font-weight: 500;
      line-height: 1.25;
    }

    /* Skills */

    .skills-list {
      display: flex;
      flex-direction: column;
    }

    .skill-row {
      display: grid;
      grid-template-columns: 2.55rem minmax(8rem, 0.85fr) minmax(0, 1.45fr);
      gap: 0.85rem;
      align-items: center;
      min-height: 5.45rem;
      padding: 0.95rem 0;
      border-bottom: 1px solid rgba(148, 163, 184, 0.24);
    }

    .skill-row:first-child {
      padding-top: 0.35rem;
    }

    .skill-row:last-child {
      border-bottom: 0;
    }

    .skill-icon {
      display: flex;
      width: 2.3rem;
      height: 2.3rem;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(16, 185, 129, 0.22);
      border-radius: 50%;
      background: rgba(16, 185, 129, 0.025);
      color: #10b981;
      font-size: 0.95rem;
    }

    .skill-row h3 {
      margin: 0;
      color: #1e293b;
      font-size: 0.76rem;
      font-weight: 750;
      line-height: 1.38;
    }

    .skill-details {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.08rem 0.3rem;
      color: #64748b;
      font-size: 0.68rem;
      line-height: 1.72;
    }

    .skill-separator {
      color: #94a3b8;
    }

    /* ══════════════════════════════════════════
       EXPERIENCE
       ══════════════════════════════════════════ */

    .experience-list {
      position: relative;
      border-top: 1px solid rgba(148, 163, 184, 0.28);
    }

   .experience-row {
  display: grid;
