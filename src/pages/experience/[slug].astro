---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('experience');
  return all.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout
  title={entry.data.title}
  description={`${entry.data.company}${entry.data.location ? ` — ${entry.data.location}` : ''}`}
>
  <div class="space-y-6 fade-in-up">
    <a
      href="/experience"
      class="t-mono t-meta inline-flex items-center gap-2 text-xs hover:text-slate-900 dark:hover:text-emerald-300"
    >
      <span aria-hidden="true">←</span> BACK TO EXPERIENCE
    </a>

    <header class="space-y-4">
      <div class="t-mono t-meta text-xs">
        $ cat ./experience/{entry.slug}.md <span class="cursor-blink ml-1">|</span>
      </div>

      <!-- Top metadata row: date · company — location -->
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 t-mono text-sm sm:text-base text-slate-600 dark:text-slate-300">
  <span>
    {(entry.data.start ?? '')}{entry.data.end ? ` – ${entry.data.end}` : ' – Present'}
  </span>

  <span class="text-slate-400 dark:text-white/30">·</span>

  <span>
    <span class="font-semibold text-slate-900 dark:text-[#d7fbe7]">
      {entry.data.company}
    </span>
    {entry.data.location ? ` — ${entry.data.location}` : ''}
  </span>
</div>
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-emerald-300">
        {entry.data.title}
      </h1>

      {entry.data.summary ? (
        <p class="t-muted max-w-3xl text-[15px] leading-7 sm:text-base sm:leading-relaxed">
          {entry.data.summary}
        </p>
      ) : null}

      <div class="mt-4 space-y-2">
  <div class="t-mono text-[11px] tracking-wider text-slate-500 uppercase dark:text-emerald-400">
    SKILLS & TOOLS
  </div>

  <div class="flex flex-wrap gap-2.5">
    {entry.data.tags.map((t) => (
      <span class="t-badge t-mono rounded-full px-3 py-1.5 text-[11px] sm:px-4 sm:py-2 sm:text-xs">
        {t}
      </span>
    ))}
  </div>
</div>

      {entry.data.tags?.length ? (
        <div class="flex flex-wrap gap-2.5">
          {entry.data.tags.map((t) => (
            <span class="t-badge t-mono rounded-full px-3 py-1.5 text-[11px] sm:px-4 sm:py-2 sm:text-xs">
              {t}
            </span>
          ))}
        </div>
      ) : null}
    </header>

    <article class="t-card p-5 md:p-8">
      <div class="prose prose-slate max-w-none dark:prose-invert">
        <Content />
      </div>
    </article>
  </div>

  <style>
    :global(html),
    :global(body) {
      overflow-x: hidden;
    }

    :global(.dark .prose) {
      color: rgba(215, 251, 231, 0.86);
    }
    :global(.dark .prose strong) {
      color: rgba(215, 251, 231, 0.95);
    }
    :global(.dark .prose a) {
      color: rgba(110, 231, 183, 0.95);
      text-decoration: none;
    }
    :global(.dark .prose a:hover) {
      text-decoration: underline;
    }
    :global(.dark .prose code) {
      color: rgba(134, 239, 172, 0.95);
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.10);
      padding: 0.15rem 0.35rem;
      border-radius: 0.5rem;
    }
    :global(.dark .prose pre) {
      background: rgba(0, 0, 0, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.10);
      overflow-x: auto;
    }
    :global(.dark .prose hr) {
      border-color: rgba(255, 255, 255, 0.10);
    }
    :global(.dark .prose blockquote) {
      border-left-color: rgba(34, 197, 94, 0.35);
    }
  </style>
</BaseLayout>