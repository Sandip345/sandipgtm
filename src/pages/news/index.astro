---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const formatDate = (value) => {
  if (!value) return '';

  const date = new Date(`${value}T00:00:00`);

  if (Number.isNaN(date.getTime())) {
    return value;
  }

  return date.toLocaleDateString(undefined, {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
};

const items = (await getCollection('news'))
  .slice()
  .sort((a, b) => {
    const aTime = new Date(`${a.data.date ?? ''}T00:00:00`).getTime();
    const bTime = new Date(`${b.data.date ?? ''}T00:00:00`).getTime();

    const safeATime = Number.isNaN(aTime) ? 0 : aTime;
    const safeBTime = Number.isNaN(bTime) ? 0 : bTime;

    return safeBTime - safeATime;
  });
---

<BaseLayout
  title="News"
  description="Personal updates, milestones, current work, and recent activities"
>
  <!-- ═══════════════ PAGE HEADER ═══════════════ -->
  <header class="news-header fade-in-up">
    <div>
      <div class="page-eyebrow t-mono">CURRENTLY & RECENTLY</div>

      <h1>News</h1>

      <p class="t-muted">
        Personal updates, current work, research milestones, conference news,
        and other highlights from what I am doing these days.
      </p>
    </div>

    <div
      class="news-count t-mono"
      aria-label={`${items.length} news updates`}
    >
      <span>{String(items.length).padStart(2, '0')}</span>
      <small>UPDATES</small>
    </div>
  </header>

  <!-- ═══════════════ NEWS TIMELINE ═══════════════ -->
  <section class="news-list fade-in-up delay-1">
    {items.map((item, index) => {
      const number = String(index + 1).padStart(2, '0');

      return (
        <a
          href={`/news/${item.slug}`}
          class="news-entry group focus:outline-none focus:ring-2 focus:ring-emerald-400"
          aria-label={`Read update: ${item.data.title}`}
        >
          <div class="news-date t-mono">
            {item.data.date ? formatDate(item.data.date) : 'Recent update'}
          </div>

          <div class="news-marker" aria-hidden="true">
            <span></span>
          </div>

          <div class="news-content">
            <div class="news-topline">
              <span class="news-number t-mono">
                UPDATE {number}
              </span>

              {index === 0 ? (
                <span class="news-latest t-mono">
                  LATEST
                </span>
              ) : null}
            </div>

            <h2>{item.data.title}</h2>

            {item.data.description ? (
              <p>{item.data.description}</p>
            ) : null}

            <div class="news-link t-mono">
              READ UPDATE
              <span aria-hidden="true">↗</span>
            </div>
          </div>
        </a>
      );
    })}
  </section>

  <style>
    /* ══════════════════════════════════════════
       PAGE HEADER
       ══════════════════════════════════════════ */

    .news-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 3rem;
      padding: 1.5rem 0 2rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.28);
    }

    .page-eyebrow {
      margin-bottom: 0.7rem;
      color: #10b981;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.11em;
    }

    .news-header h1 {
      margin: 0;
      color: #0f172a;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 750;
      line-height: 1.1;
      letter-spacing: -0.035em;
    }

    .news-header p {
      max-width: 44rem;
      margin: 0.85rem 0 0;
      font-size: 0.94rem;
      line-height: 1.75;
    }

    .news-count {
      display: flex;
      min-width: 5rem;
      flex-direction: column;
      align-items: flex-end;
      color: #64748b;
    }

    .news-count span {
      color: #0f172a;
      font-size: 1.8rem;
      font-weight: 700;
      line-height: 1;
    }

    .news-count small {
      margin-top: 0.35rem;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.12em;
    }

    /* ══════════════════════════════════════════
       NEWS TIMELINE
       ══════════════════════════════════════════ */

    .news-list {
      position: relative;
    }

    .news-entry {
      display: grid;
      grid-template-columns: 8.6rem 1.15rem minmax(0, 1fr);
      gap: 1.15rem;
      padding: 2.75rem 0;
      border-bottom: 1px solid rgba(148, 163, 184, 0.25);
      color: inherit;
      text-decoration: none;
    }

    .news-date {
      padding-top: 0.25rem;
      color: #059669;
      font-size: 0.67rem;
      line-height: 1.65;
    }

    .news-marker {
      position: relative;
      display: flex;
      justify-content: center;
    }

    .news-marker::after {
      content: "";
      position: absolute;
      top: 0.75rem;
      bottom: -2.75rem;
      left: 50%;
      width: 1px;
      background: linear-gradient(
        to bottom,
        rgba(16, 185, 129, 0.72),
        rgba(148, 163, 184, 0.25)
      );
      transform: translateX(-50%);
    }

    .news-entry:last-child .news-marker::after {
      bottom: 0;
    }

    .news-marker span {
      position: relative;
      z-index: 1;
      width: 0.82rem;
      height: 0.82rem;
      margin-top: 0.25rem;
      border: 2px solid #6ee7b7;
      border-radius: 50%;
      background: #10b981;
      box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
    }

    .news-content {
      min-width: 0;
    }

    .news-topline {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .news-number {
      color: #059669;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
    }

    .news-latest {
      display: inline-flex;
      align-items: center;
      gap: 0.38rem;
      color: #64748b;
      font-size: 0.57rem;
      font-weight: 700;
      letter-spacing: 0.09em;
    }

    .news-latest::before {
      content: "";
      width: 0.38rem;
      height: 0.38rem;
      border-radius: 50%;
      background: #10b981;
      box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }

    .news-content h2 {
      max-width: 42rem;
      margin: 0;
      color: #0f172a;
      font-size: clamp(1.25rem, 2.2vw, 1.7rem);
      font-weight: 750;
      line-height: 1.4;
      letter-spacing: -0.02em;
      transition: color 160ms ease;
    }

    .news-entry:hover .news-content h2 {
      color: #059669;
    }

    .news-content p {
      max-width: 51rem;
      margin: 0.85rem 0 0;
      color: #475569;
      font-size: 0.88rem;
      line-height: 1.8;
    }

    .news-link {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      margin-top: 1.15rem;
      color: #059669;
      font-size: 0.63rem;
      font-weight: 700;
      letter-spacing: 0.08em;
    }

    .news-link span {
      transition: transform 160ms ease;
    }

    .news-entry:hover .news-link span {
      transform: translate(2px, -2px);
    }

    /* Dark mode */

    :global(.dark) .news-header,
    :global(.dark) .news-entry {
      border-color: rgba(255, 255, 255, 0.1);
    }

    :global(.dark) .news-header h1,
    :global(.dark) .news-count span,
    :global(.dark) .news-content h2 {
      color: #d7fbe7;
    }

    :global(.dark) .news-count,
    :global(.dark) .news-latest {
      color: #94a3b8;
    }

    :global(.dark) .news-content p {
      color: #cbd5e1;
    }

    /* Responsive */

    @media (max-width: 760px) {
      .news-header {
        align-items: flex-start;
      }

      .news-count {
        min-width: auto;
      }

      .news-entry {
        grid-template-columns: 0.9rem minmax(0, 1fr);
        gap: 0.8rem;
        padding: 2.3rem 0;
      }

      .news-date {
        grid-column: 2;
        grid-row: 1;
        padding: 0;
      }

      .news-marker {
        grid-column: 1;
        grid-row: 1 / span 2;
      }

      .news-marker::after {
        bottom: -2.3rem;
      }

      .news-content {
        grid-column: 2;
        grid-row: 2;
      }
    }

    @media (max-width: 520px) {
      .news-header {
        display: block;
      }

      .news-count {
        display: none;
      }

      .news-header p {
        font-size: 0.86rem;
      }

      .news-content h2 {
        font-size: 1.22rem;
      }

      .news-content p {
        font-size: 0.83rem;
      }
    }
  </style>
</BaseLayout>
