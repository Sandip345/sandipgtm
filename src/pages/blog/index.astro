---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('blog'))
  .slice()
  .sort((a, b) =>
    (b.data.date ?? '').localeCompare(a.data.date ?? '')
  );
---

<BaseLayout
  title="Blog"
  description="Thoughts, lessons, and engineering reflections"
>
  <section class="blog-page fade-in-up">
    <!-- Page heading -->
    <header class="blog-header">
      <div>
        <span class="blog-eyebrow t-mono">
          ENGINEERING NOTES
        </span>

        <h1>Blog</h1>

        <p>
          Thoughts, lessons, and engineering reflections.
        </p>
      </div>

      <div class="blog-count t-mono">
        {items.length}
        {items.length === 1 ? ' POST' : ' POSTS'}
      </div>
    </header>

    <!-- Blog list -->
    {items.length ? (
      <div class="blog-list fade-in-up delay-1">
        {items.map((item, index) => {
          const tags = Array.isArray(item.data.tags)
            ? item.data.tags
            : [];

          return (
            <a
              href={`/blog/${item.slug}`}
              class="blog-row group focus:outline-none focus:ring-2 focus:ring-emerald-400"
              aria-label={`Read blog post: ${item.data.title}`}
            >
              <div class="blog-number t-mono">
                {String(index + 1).padStart(2, '0')}
              </div>

              <div class="blog-main">
                <div class="blog-meta">
                  {item.data.date ? (
                    <time class="blog-date t-mono">
                      {item.data.date}
                    </time>
                  ) : null}

                  {tags.length ? (
                    <div class="blog-tags">
                      {tags.map((tag, tagIndex) => (
                        <>
                          <span>{tag}</span>

                          {tagIndex < tags.length - 1 ? (
                            <span
                              class="blog-tag-separator"
                              aria-hidden="true"
                            >
                              ·
                            </span>
                          ) : null}
                        </>
                      ))}
                    </div>
                  ) : null}
                </div>

                <h2>{item.data.title}</h2>

                {item.data.description ? (
                  <p>{item.data.description}</p>
                ) : null}
              </div>

              <div class="blog-open t-mono">
                READ
                <span aria-hidden="true">↗</span>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="blog-empty">
        <span class="t-mono">NO POSTS YET</span>
        <p>New engineering notes will appear here.</p>
      </div>
    )}
  </section>

  <style>
    /* ══════════════════════════════════════════
       BLOG INDEX
       ══════════════════════════════════════════ */

    .blog-page {
      width: 100%;
    }

    .blog-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
      margin-bottom: 2rem;
      padding-bottom: 1.4rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.28);
    }

    .blog-eyebrow {
      display: block;
      margin-bottom: 0.55rem;
      color: #10b981;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.11em;
    }

    .blog-header h1 {
      margin: 0;
      color: #0f172a;
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 750;
      line-height: 1.15;
      letter-spacing: -0.035em;
    }

    .blog-header p {
      max-width: 38rem;
      margin: 0.7rem 0 0;
      color: #64748b;
      font-size: 0.9rem;
      line-height: 1.7;
    }

    .blog-count {
      flex-shrink: 0;
      color: #94a3b8;
      font-size: 0.64rem;
      font-weight: 700;
      letter-spacing: 0.08em;
    }

    /* Blog rows */

    .blog-list {
      border-top: 1px solid rgba(148, 163, 184, 0.24);
    }

    .blog-row {
      display: grid;
      grid-template-columns: 2.2rem minmax(0, 1fr) auto;
      gap: 1.4rem;
      align-items: start;
      padding: 1.8rem 0;
      border-bottom: 1px solid rgba(148, 163, 184, 0.24);
      color: inherit;
      text-decoration: none;
      transition:
        background-color 160ms ease,
        transform 160ms ease;
    }

    .blog-row:hover {
      transform: translateX(2px);
    }

    .blog-number {
      padding-top: 0.15rem;
      color: #10b981;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.06em;
    }

    .blog-main {
      min-width: 0;
    }

    .blog-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.35rem 0.8rem;
      color: #64748b;
      font-size: 0.68rem;
      line-height: 1.6;
    }

    .blog-date {
      color: #059669;
      font-weight: 600;
    }

    .blog-tags {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.1rem 0.35rem;
    }

    .blog-tag-separator {
      color: #10b981;
    }

    .blog-main h2 {
      margin: 0.55rem 0 0;
      color: #0f172a;
      font-size: clamp(1.05rem, 2vw, 1.35rem);
      font-weight: 750;
      line-height: 1.4;
      letter-spacing: -0.02em;
      transition:
        color 160ms ease,
        transform 160ms ease;
    }

    .blog-row:hover .blog-main h2 {
      color: #059669;
      transform: translateY(-1px);
    }

    .blog-main p {
      max-width: 58rem;
      margin: 0.7rem 0 0;
      color: #64748b;
      font-size: 0.84rem;
      line-height: 1.75;
    }

    .blog-open {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding-top: 0.15rem;
      color: #94a3b8;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      white-space: nowrap;
    }

    .blog-open span {
      color: #10b981;
      transition: transform 160ms ease;
    }

    .blog-row:hover .blog-open span {
      transform: translate(2px, -2px);
    }

    /* Empty state */

    .blog-empty {
      padding: 3rem 0;
      border-top: 1px solid rgba(148, 163, 184, 0.24);
      border-bottom: 1px solid rgba(148, 163, 184, 0.24);
      text-align: center;
    }

    .blog-empty span {
      color: #10b981;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.1em;
    }

    .blog-empty p {
      margin: 0.65rem 0 0;
      color: #64748b;
      font-size: 0.84rem;
    }

    /* Dark mode */

    :global(.dark) .blog-header,
    :global(.dark) .blog-list,
    :global(.dark) .blog-row,
    :global(.dark) .blog-empty {
      border-color: rgba(255, 255, 255, 0.1);
    }

    :global(.dark) .blog-header h1,
    :global(.dark) .blog-main h2 {
      color: #d7fbe7;
    }

    :global(.dark) .blog-header p,
    :global(.dark) .blog-main p,
    :global(.dark) .blog-meta {
      color: #9ca7b4;
    }

    :global(.dark) .blog-count,
    :global(.dark) .blog-open {
      color: #718096;
    }

    :global(.dark) .blog-row:hover .blog-main h2 {
      color: #34d399;
    }

    :global(.dark) .blog-empty p {
      color: #9ca7b4;
    }

    /* Responsive */

    @media (max-width: 640px) {
      .blog-header {
        align-items: flex-start;
        flex-direction: column;
        gap: 0.8rem;
      }

      .blog-count {
        order: -1;
      }

      .blog-row {
        grid-template-columns: 1.7rem minmax(0, 1fr);
        gap: 0.9rem;
      }

      .blog-open {
        grid-column: 2;
        margin-top: 0.2rem;
      }

      .blog-main h2 {
        font-size: 1.05rem;
      }

      .blog-main p {
        font-size: 0.8rem;
      }
    }
  </style>
</BaseLayout>