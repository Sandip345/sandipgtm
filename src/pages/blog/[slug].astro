---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('blog');

  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();

const tags = Array.isArray(item.data.tags)
  ? item.data.tags
  : [];
---

<BaseLayout
  title={`${item.data.title} — Blog`}
  description={item.data.description}
>
  <div class="blog-post mx-auto w-full max-w-4xl fade-in-up">
    <a
      href="/blog"
      class="back-link t-mono focus:outline-none focus:ring-2 focus:ring-emerald-400"
      aria-label="Back to blog"
    >
      <span aria-hidden="true">←</span>
      BACK TO BLOG
    </a>

    <header class="post-header">
      <div class="post-eyebrow t-mono">
        ENGINEERING NOTE
      </div>

      <h1>{item.data.title}</h1>

      {(item.data.date || tags.length) ? (
        <div class="post-meta">
          {item.data.date ? (
            <time class="post-date t-mono">
              {item.data.date}
            </time>
          ) : null}

          {item.data.date && tags.length ? (
            <span
              class="meta-divider"
              aria-hidden="true"
            >
              /
            </span>
          ) : null}

          {tags.length ? (
            <div
              class="post-tags"
              aria-label="Post tags"
            >
              {tags.map((tag, index) => (
                <>
                  <span>{tag}</span>

                  {index < tags.length - 1 ? (
                    <span
                      class="tag-separator"
                      aria-hidden="true"
                    >
                      ·
                    </span>
                  ) : null}
                </>
              ))}
            </div>
          ) : null}
        </div>
      ) : null}

      {item.data.description ? (
        <p class="post-description">
          {item.data.description}
        </p>
      ) : null}
    </header>

    <article class="post-content">
      <div class="prose prose-slate max-w-none dark:prose-invert">
        <Content />
      </div>
    </article>

    <div class="post-footer-nav">
      <a
        href="/blog"
        class="bottom-back-link t-mono focus:outline-none focus:ring-2 focus:ring-emerald-400"
      >
        <span aria-hidden="true">←</span>
        VIEW ALL POSTS
      </a>

      <a
        href="#top"
        class="bottom-top-link t-mono focus:outline-none focus:ring-2 focus:ring-emerald-400"
      >
        BACK TO TOP
        <span aria-hidden="true">↑</span>
      </a>
    </div>
  </div>

  <style>
    .blog-post {
      padding-top: 0.5rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border-radius: 0.35rem;
      color: #64748b;
      font-size: 0.64rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-decoration: none;
      transition:
        color 160ms ease,
        transform 160ms ease;
    }

    .back-link:hover {
      color: #059669;
      transform: translateX(-2px);
    }

    .post-header {
      width: 100%;
      padding: 2.1rem 0 2rem;
    }

    .post-eyebrow {
      margin-bottom: 0.75rem;
      color: #10b981;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.11em;
      text-transform: uppercase;
    }

    .post-header h1 {
      width: 100%;
      margin: 0;
      color: #0f172a;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.035em;
      overflow-wrap: break-word;
    }

    .post-meta {
      display: flex;
      width: 100%;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.35rem 0.75rem;
      margin-top: 1rem;
      color: #64748b;
      font-size: 0.72rem;
      line-height: 1.7;
    }

    .post-date {
      color: #059669;
      font-weight: 600;
    }

    .meta-divider {
      color: #cbd5e1;
    }

    .post-tags {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.1rem 0.35rem;
    }

    .tag-separator {
      color: #10b981;
    }

    .post-description {
      width: 100%;
      margin: 1.15rem 0 0;
      color: #475569;
      font-size: 0.96rem;
      line-height: 1.8;
    }

    .post-content {
      margin-top: 2.2rem;
    }

    :global(.post-content .prose) {
      width: 100%;
      max-width: none;
      color: #475569;
      font-size: 0.96rem;
      line-height: 1.85;
    }

    :global(.post-content .prose > :first-child) {
      margin-top: 0;
    }

    :global(.post-content .prose h2) {
      margin-top: 3rem;
      margin-bottom: 1rem;
      padding-bottom: 0.7rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.22);
      color: #0f172a;
      font-size: clamp(1.4rem, 2.4vw, 1.8rem);
      font-weight: 750;
      line-height: 1.35;
      letter-spacing: -0.025em;
    }

    :global(.post-content .prose h3) {
      margin-top: 2.2rem;
      margin-bottom: 0.75rem;
      color: #1e293b;
      font-size: 1.15rem;
      font-weight: 700;
      line-height: 1.45;
    }

    :global(.post-content .prose p) {
      width: 100%;
      margin: 1rem 0;
      line-height: 1.85;
      letter-spacing: 0.005em;
      text-align: left;
    }

    :global(.post-content .prose strong) {
      color: #1e293b;
      font-weight: 700;
    }

    :global(.post-content .prose ul) {
      margin: 1.1rem 0;
      padding-left: 0;
      list-style: none;
    }

    :global(.post-content .prose ul li) {
      position: relative;
      margin-top: 0.65rem;
      padding-left: 1.2rem;
      line-height: 1.8;
    }

    :global(.post-content .prose ul li::before) {
      content: "";
      position: absolute;
      top: 0.74em;
      left: 0;
      width: 0.3rem;
      height: 0.3rem;
      border-radius: 50%;
      background: #10b981;
    }

    :global(.post-content .prose a) {
      color: #059669;
      font-weight: 600;
      text-decoration-color: rgba(16, 185, 129, 0.35);
      text-underline-offset: 0.2em;
    }

    :global(.post-content .prose a:hover) {
      color: #047857;
      text-decoration-color: currentColor;
    }

    :global(.post-content .prose figure) {
      display: flex;
      width: 100%;
      flex-direction: column;
      align-items: center;
      margin: 2.25rem 0;
    }

    :global(.post-content .prose figure :is(img, div)) {
      margin: 0;
    }

    :global(.post-content .prose img) {
      display: block;
      width: 100%;
      height: auto;
      margin: 2rem 0;
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 0.85rem;
      box-shadow: 0 12px 30px rgba(15, 23, 42, 0.05);
    }

    :global(.post-content .prose figure img) {
      width: auto;
      max-width: 100%;
      margin: 0;
    }

    :global(.post-content .prose figcaption) {
      display: block;
      width: 100%;
      margin-top: 0.75rem;
      color: #64748b;
      font-size: 0.78rem;
      font-style: italic;
      line-height: 1.5;
      text-align: center;
    }

    :global(.post-content .prose code) {
      padding: 0.15rem 0.35rem;
      border: 1px solid rgba(16, 185, 129, 0.15);
      border-radius: 0.35rem;
      background: rgba(16, 185, 129, 0.06);
      color: #047857;
      font-size: 0.88em;
    }

    :global(.post-content .prose pre) {
      overflow-x: auto;
      margin: 2rem 0;
      padding: 1.15rem;
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 0.8rem;
      background: #0f172a;
      color: #e2e8f0;
    }

    :global(.post-content .prose pre code) {
      padding: 0;
      border: 0;
      background: transparent;
      color: inherit;
    }

    :global(.post-content .prose blockquote) {
      margin: 2rem 0;
      padding: 0.2rem 0 0.2rem 1.2rem;
      border-left: 3px solid rgba(16, 185, 129, 0.55);
      color: #64748b;
      font-style: italic;
    }

    :global(.post-content .prose hr) {
      margin: 2.5rem 0;
      border-color: rgba(148, 163, 184, 0.2);
    }

    .post-footer-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid rgba(148, 163, 184, 0.24);
    }

    .bottom-back-link,
    .bottom-top-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border-radius: 0.35rem;
      color: #64748b;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-decoration: none;
      transition:
        color 160ms ease,
        transform 160ms ease;
    }

    .bottom-back-link:hover {
      color: #059669;
      transform: translateX(-2px);
    }

    .bottom-top-link:hover {
      color: #059669;
      transform: translateY(-2px);
    }

    :global(.dark) .post-header h1,
    :global(.dark .post-content .prose h2),
    :global(.dark .post-content .prose h3) {
      color: #d7fbe7;
    }

    :global(.dark) .post-meta,
    :global(.dark) .post-description {
      color: #aeb8c4;
    }

    :global(.dark .post-content .prose) {
      color: #9ca7b4;
    }

    :global(.dark .post-content .prose strong) {
      color: #cfd8e3;
    }

    :global(.dark .post-content .prose h2) {
      border-color: rgba(255, 255, 255, 0.09);
    }

    :global(.dark .post-content .prose img) {
      border-color: rgba(255, 255, 255, 0.09);
      box-shadow:
        0 0 0 1px rgba(34, 197, 94, 0.04),
        0 16px 42px rgba(0, 0, 0, 0.35);
      filter: brightness(0.9) contrast(1.03);
    }

    :global(.dark .post-content .prose figcaption) {
      color: #718096;
    }

    :global(.dark .post-content .prose code) {
      border-color: rgba(52, 211, 153, 0.18);
      background: rgba(16, 185, 129, 0.07);
      color: #86efac;
    }

    :global(.dark .post-content .prose pre) {
      border-color: rgba(255, 255, 255, 0.09);
      background: rgba(0, 0, 0, 0.36);
    }

    :global(.dark .post-content .prose blockquote) {
      border-left-color: rgba(52, 211, 153, 0.4);
      color: #9ca7b4;
    }

    :global(.dark .post-content .prose hr),
    :global(.dark) .post-footer-nav {
      border-color: rgba(255, 255, 255, 0.09);
    }

    :global(.dark) .back-link,
    :global(.dark) .bottom-back-link,
    :global(.dark) .bottom-top-link {
      color: #94a3b8;
    }

    :global(.dark) .back-link:hover,
    :global(.dark) .bottom-back-link:hover,
    :global(.dark) .bottom-top-link:hover {
      color: #34d399;
    }

    @media (max-width: 640px) {
      .post-header {
        padding: 1.8rem 0 1.6rem;
      }

      .post-header h1 {
        font-size: clamp(1.75rem, 8vw, 2.15rem);
        line-height: 1.2;
      }

      .post-description {
        font-size: 0.9rem;
      }

      .post-meta {
        display: block;
      }

      .meta-divider {
        display: none;
      }

      .post-tags {
        margin-top: 0.45rem;
      }

      .post-content {
        margin-top: 1.8rem;
      }

      :global(.post-content .prose) {
        font-size: 0.9rem;
      }

      :global(.post-content .prose h2) {
        margin-top: 2.4rem;
        font-size: 1.35rem;
      }

      .post-footer-nav {
        align-items: flex-start;
        flex-direction: column;
        gap: 1rem;
      }
    }
  </style>
</BaseLayout>