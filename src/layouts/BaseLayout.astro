---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>

    {description ? (
      <meta
        name="description"
        content={description}
      />
    ) : null}

    <!-- Browser theme colors -->
    <meta
      name="theme-color"
      content="#f8fafc"
      media="(prefers-color-scheme: light)"
    />

    <meta
      name="theme-color"
      content="#050607"
      media="(prefers-color-scheme: dark)"
    />

    <!-- Open Graph metadata -->
    <meta
      property="og:title"
      content={title}
    />

    {description ? (
      <meta
        property="og:description"
        content={description}
      />
    ) : null}

    <meta
      property="og:type"
      content="website"
    />

    <!-- Google Fonts: DM Sans + JetBrains Mono -->
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />

    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />

    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Theme initialization: default light, respect saved preference -->
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem('theme');
          const theme = savedTheme ?? 'light';

          document.documentElement.classList.toggle(
            'dark',
            theme === 'dark'
          );

          if (!savedTheme) {
            localStorage.setItem('theme', 'light');
          }
        } catch {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <!-- Google Analytics -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-G6W0KH2LEG"
    ></script>

    <script is:inline>
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        window.dataLayer.push(arguments);
      }

      gtag('js', new Date());
      gtag('config', 'G-G6W0KH2LEG');
    </script>
  </head>

  <body
    class="min-h-screen bg-slate-50 font-sans text-slate-900 antialiased dark:bg-[#050607] dark:text-[#d7fbe7]"
  >
    <div id="top"></div>

    <Header />

    <!-- Light-mode background glow -->
    <div
      class="pointer-events-none fixed inset-0 -z-10
             bg-[radial-gradient(circle_at_top,rgba(16,185,129,0.08),transparent_55%)]
             dark:hidden"
      aria-hidden="true"
    ></div>

    <main
      class="mx-auto max-w-5xl px-5 pt-10 pb-6 sm:px-6 sm:pt-12 sm:pb-8 lg:px-8"
    >
      <slot />
    </main>

    <Footer />

    <style>
      :global(html) {
        color-scheme: light dark;
        scroll-behavior: smooth;
        scroll-padding-top: 5rem;
      }

      :global(body) {
        transition:
          background-color 0.2s ease,
          color 0.2s ease;
      }

      /* Dark background treatment */

      :global(.dark body) {
        background:
          radial-gradient(
            900px 500px at 20% 0%,
            rgba(34, 197, 94, 0.1),
            transparent 60%
          ),
          radial-gradient(
            700px 380px at 90% 10%,
            rgba(56, 189, 248, 0.06),
            transparent 55%
          ),
          linear-gradient(
            to bottom,
            rgba(255, 255, 255, 0.015),
            rgba(255, 255, 255, 0)
          ),
          repeating-linear-gradient(
            to bottom,
            rgba(255, 255, 255, 0.01),
            rgba(255, 255, 255, 0.01) 1px,
            rgba(0, 0, 0, 0) 3px,
            rgba(0, 0, 0, 0) 6px
          ),
          #050607;
      }

      /* Links */

      :global(a) {
        transition:
          color 0.15s ease,
          border-color 0.15s ease,
          background-color 0.15s ease,
          transform 0.15s ease;
      }

      /*
       * Components control their own dark-mode link colors.
       * Keeping global links inherited prevents large clickable rows
       * from unexpectedly turning green.
       */
      :global(.dark a) {
        color: inherit;
      }

      /* Text helpers */

      :global(.t-muted) {
        color: rgb(71 85 105);
      }

      :global(.t-meta) {
        color: rgb(100 116 139);
      }

      :global(.dark .t-muted) {
        color: rgba(215, 251, 231, 0.72);
      }

      :global(.dark .t-meta) {
        color: rgba(215, 251, 231, 0.55);
      }

      /* Cards */

      :global(.t-card) {
        border: 1px solid rgba(226, 232, 240, 0.8);
        border-radius: 20px;
        background: #ffffff;
        box-shadow:
          0 1px 2px rgba(15, 23, 42, 0.04),
          0 4px 16px rgba(15, 23, 42, 0.05);
        transition:
          transform 0.18s ease,
          box-shadow 0.18s ease,
          border-color 0.18s ease;
      }

      :global(.t-card:hover) {
        transform: translateY(-3px);
        box-shadow:
          0 8px 24px rgba(15, 23, 42, 0.08),
          0 16px 48px rgba(15, 23, 42, 0.06);
      }

      :global(.dark .t-card) {
        border-color: rgba(255, 255, 255, 0.08);
        background: rgba(15, 20, 24, 0.85);
        box-shadow: 0 0 0 1px rgba(34, 197, 94, 0.05);
      }

      :global(.dark .t-card:hover) {
        border-color: rgba(34, 197, 94, 0.25);
        box-shadow:
          0 0 0 1px rgba(34, 197, 94, 0.1),
          0 18px 50px rgba(0, 0, 0, 0.55);
      }

      /* Badges and chips */

      :global(.t-badge) {
        padding: 0.25rem 0.75rem;
        border: 1px solid rgba(16, 185, 129, 0.14);
        border-radius: 9999px;
        background: rgba(16, 185, 129, 0.07);
        color: rgb(6 78 59);
        font-size: 0.75rem;
        font-weight: 500;
      }

      :global(.dark .t-badge) {
        border-color: rgba(34, 197, 94, 0.18);
        background: rgba(34, 197, 94, 0.1);
        color: rgba(134, 239, 172, 0.95);
      }

      /* Monospace utility */

      :global(.t-mono) {
        font-family:
          'JetBrains Mono',
          ui-monospace,
          SFMono-Regular,
          Menlo,
          Monaco,
          Consolas,
          "Liberation Mono",
          "Courier New",
          monospace;
        letter-spacing: -0.01em;
      }

      /* Cursor blink */

      :global(.cursor-blink) {
        display: inline-block;
        color: #34d399;
        animation: blink 1s steps(2, start) infinite;
      }

      @keyframes blink {
        0%,
        50%,
        100% {
          opacity: 1;
        }

        25%,
        75% {
          opacity: 0;
        }
      }

      /* Prose media */

      :global(.prose img) {
        border: 1px solid rgb(226 232 240);
        border-radius: 16px;
      }

      :global(.dark .prose img) {
        border-color: rgba(255, 255, 255, 0.1);
        box-shadow:
          0 0 0 1px rgba(34, 197, 94, 0.06),
          0 18px 50px rgba(0, 0, 0, 0.55);
        filter:
          brightness(0.85)
          contrast(1.05)
          saturate(0.95);
      }

      :global(.prose figcaption) {
        margin-top: 0.5rem;
        color: rgb(100 116 139);
        font-size: 0.875rem;
      }

      :global(.dark .prose figcaption) {
        color: rgba(215, 251, 231, 0.55);
      }

      /* Dark prose tables */

      :global(.dark .prose table) {
        border-color: rgba(255, 255, 255, 0.1);
      }

      :global(.dark .prose thead) {
        border-bottom-color: rgba(255, 255, 255, 0.12);
      }

      :global(.dark .prose th) {
        color: rgba(215, 251, 231, 0.92);
      }

      :global(.dark .prose td) {
        border-color: rgba(255, 255, 255, 0.08);
      }

      /* Reduced motion */

      @media (prefers-reduced-motion: reduce) {
        :global(html) {
          scroll-behavior: auto;
        }

        :global(*),
        :global(*::before),
        :global(*::after) {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </body>
</html>